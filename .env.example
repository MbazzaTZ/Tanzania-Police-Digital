# =========================================================
# TPDOP – Environment Variables
# Copy to .env.local and fill in your values
# =========================================================

# ── SUPABASE ──
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── APP ──
VITE_APP_NAME=TPDOP
VITE_APP_VERSION=1.0.0
VITE_APP_ENV=development     # development | staging | production

# ── FEATURES (set to 'true' or 'false') ──
VITE_ENABLE_GPS=true         # Live GPS tracking
VITE_ENABLE_BIOMETRIC=true   # Fingerprint login
VITE_ENABLE_AUDIT=true       # Audit trail logging
VITE_ENABLE_INTELLIGENCE=true # Intelligence module (RPC+ only)

# ── EXTERNAL INTEGRATIONS (server-side, NOT exposed to client) ──
# These go in Supabase Edge Function secrets — NOT in this file
# NIDA_API_URL=https://api.nida.go.tz/v1
# NIDA_API_KEY=...
# TAZARA_API_URL=https://api.tazara.go.tz/v1
# TAZARA_API_KEY=...
# TRA_TIN_API_URL=https://api.tra.go.tz/v1
# TRA_TIN_API_KEY=...
# INEC_API_URL=https://api.inec.go.tz/v1
# INEC_API_KEY=...
